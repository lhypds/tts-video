# TTS Engine Configuration
# Options: "openai" or "minimax"
TTS_ENGINE="openai"

# OpenAI Configuration
OPENAI_API_KEY=
# Voice options: alloy, echo, fable, onyx, nova, shimmer
OPENAI_TTS_VOICE="alloy"

# Minimax Configuration (used when TTS_ENGINE="minimax")
MINIMAX_API_KEY=
MINIMAX_GROUP_ID=
# Voice options for Chinese:
#   Male: male-qn-qingse, male-qn-jingying, male-qn-badao, male-qn-daxuesheng
#   Female: female-shaonv, female-yujie, female-chengshu, female-tianmei
#   Presenters: presenter_male, presenter_female
#   Audiobooks: audiobook_male_1, audiobook_male_2, audiobook_female_1, audiobook_female_2
# Voice options for English:
#   English_expressive_narrator
MINIMAX_TTS_VOICE="male-qn-qingse"

# Video Configuration
VIDEO_WIDTH=300
VIDEO_HEIGHT=400
